{
  "name": "silverbond-ui",
  "private": true,
  "version": "3.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --config ui/vite.config.ts",
    "build": "vite build --config ui/vite.config.ts",
    "preview": "vite preview --config ui/vite.config.ts",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "typecheck": "svelte-check --tsconfig ./tsconfig.json",
    "test": "vitest run --config ui/vite.config.ts",
    "test:watch": "vitest --config ui/vite.config.ts",
    "test:e2e": "npm run build && playwright test"
  },
  "dependencies": {
    "@tanstack/svelte-query": "6.1.0",
    "@xyflow/svelte": "1.1.0",
    "clsx": "^2.1.1",
    "svelte": "5.53.10"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@sveltejs/vite-plugin-svelte": "6.2.4",
    "@tauri-apps/cli": "^2.10.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/svelte": "^5.2.7",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "25.4.0",
    "jsdom": "28.1.0",
    "svelte-check": "^4.1.0",
    "typescript": "^5.8.2",
    "vite": "7.3.1",
    "vitest": "4.0.18"
  }
}
